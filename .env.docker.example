# ============================================
# LifelineAustralia — Docker Environment
# Copy to .env and fill in values
# ============================================

# Database
DB_PASSWORD=changeme_use_strong_password

# JWT (use: openssl rand -hex 64)
JWT_ACCESS_SECRET=replace-with-64-char-hex-secret
JWT_REFRESH_SECRET=replace-with-64-char-hex-secret

# CORS
CORS_ORIGIN=https://yourdomain.com
PRODUCTION_URLS=https://yourdomain.com,https://www.yourdomain.com

# Frontend build-time vars
VITE_API_BASE_URL=https://api.yourdomain.com
VITE_REALTIME_SERVER_URL=https://ws.yourdomain.com
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Stripe (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# AWS S3 (optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-2
AWS_S3_BUCKET=
