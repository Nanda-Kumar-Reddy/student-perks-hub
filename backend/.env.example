# ============================================
# LifelineAustralia Backend — Environment Variables
# Copy to .env.development and fill in values
# ============================================

# Server
NODE_ENV="development"
PORT=4000

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/lifeline_australia?schema=public"

# JWT Secrets (use `openssl rand -hex 64` to generate)
JWT_ACCESS_SECRET="your-access-secret-min-32-chars-long-replace-me"
JWT_REFRESH_SECRET="your-refresh-secret-min-32-chars-long-replace-me"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# CORS
CORS_ORIGIN="http://localhost:5173"
PRODUCTION_URLS="https://yourdomain.com,https://www.yourdomain.com"

# File Upload
MAX_FILE_SIZE_MB=10
UPLOAD_DIR="./uploads"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# AWS S3 (for file storage)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="ap-southeast-2"
AWS_S3_BUCKET=""

# Payment (Stripe)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
